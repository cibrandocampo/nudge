---
export interface Props {
  src: string
  alt: string
  caption?: string
}
const { src, alt, caption } = Astro.props
// Astro's import.meta.env.BASE_URL ends with '/' in dev and empty in prod
// builds; combine defensively.
const resolved = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/${src.replace(/^\//, '')}`
---
<figure class="flex flex-col items-center">
  <div class="rounded-[32px] border-2 border-slate-800 bg-slate-900/60 p-2 shadow-xl shadow-nudge-900/30">
    <img
      src={resolved}
      alt={alt}
      class="rounded-[24px] w-full max-w-[320px] h-auto"
      loading="lazy"
      decoding="async"
    />
  </div>
  {caption && (
    <figcaption class="mt-3 text-center text-sm text-slate-400 max-w-xs">
      {caption}
    </figcaption>
  )}
</figure>
