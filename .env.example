# ─────────────────────────────────────────────────────────
#  Nudge — Environment variables
#  Copy this file to .env and fill in the real values.
#  NEVER commit .env to the repository.
# ─────────────────────────────────────────────────────────

# ── Infrastructure ────────────────────────────────────────
# Docker Compose project name — used as a prefix for container names.
PROJECT_NAME=nudge

# Docker image tags. Use "stable" for the latest release, "latest" for the
# most recent build from main, or a specific version like "v1.2.3".
DOCKER_NUDGE_VERSION=stable
DOCKER_POSTGRES_VERSION=16-alpine
DOCKER_REDIS_VERSION=7-alpine

# Port exposed on the host for the frontend (HTTP).
# If you run a reverse proxy (nginx, Traefik, Synology, etc.) set this to
# any free port (e.g. 8080) and point the proxy to it.
NUDGE_HTTP_PORT=80

# Internal backend port (Gunicorn). Must stay 8000 unless you also update nginx.conf.
BACKEND_PORT=8000

# Gunicorn worker processes. Rule of thumb: 2 × CPU cores + 1.
GUNICORN_WORKERS=2

# Host path where PostgreSQL data is persisted. Use an absolute path in production.
DATA_PATH=./data

# ── Logging ───────────────────────────────────────────────
# Log level for each service. Each accepts its own set of valid values:
#   Django / Celery / Gunicorn: debug | info | warning | error | critical
#   Redis:                      debug | verbose | notice | warning
#   PostgreSQL:                 debug5..debug1 | info | notice | warning | error | log | fatal | panic
#   Nginx:                      debug | info | notice | warn | error | crit | alert | emerg
DJANGO_LOG_LEVEL=info
CELERY_LOG_LEVEL=info
GUNICORN_LOG_LEVEL=info
REDIS_LOG_LEVEL=notice
POSTGRES_LOG_LEVEL=warning
NGINX_LOG_LEVEL=warn

# ── Admin user ────────────────────────────────────────────
# Created automatically on first startup if no superuser exists.
# After first boot, the password can only be changed from the Django admin panel.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# ── Django ────────────────────────────────────────────────
# Secret key for cryptographic signing. Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# Avoid keys containing $ or & — they interfere with Docker Compose variable interpolation.
DJANGO_SECRET_KEY=change-me

# Must be False in production.
DJANGO_DEBUG=False

# Comma-separated list of hostnames Django will accept requests for.
# Always include your public domain and localhost — localhost is required for
# the Docker healthcheck, which contacts the backend directly on port 8000.
# Example: DJANGO_ALLOWED_HOSTS=nudge.example.com,localhost
DJANGO_ALLOWED_HOSTS=yourdomain.com,localhost

# Comma-separated list of origins allowed to make cross-site requests.
# Must match exactly what the browser sends (scheme + host + port). No trailing slash.
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Comma-separated list of origins trusted for CSRF protection.
# Must include every domain that submits forms to the backend (including the admin panel).
CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# ── Database (PostgreSQL) ─────────────────────────────────
# Use alphanumeric passwords — special characters require URL-encoding in connection
# strings, which Docker env_file does not handle. DATABASE_URL is constructed
# automatically by Docker Compose from these values.
POSTGRES_DB=nudge
POSTGRES_USER=nudge
POSTGRES_PASSWORD=change-me

# ── Redis ─────────────────────────────────────────────────
# Use an alphanumeric password — same reason as POSTGRES_PASSWORD above.
# REDIS_URL is constructed automatically by Docker Compose from this value.
REDIS_PASSWORD=change-me

# ── Web Push — VAPID keys ─────────────────────────────────
# VAPID keys authenticate push messages sent to browsers. Generate the key pair
# once and keep it safe — regenerating it invalidates all existing push subscriptions.
#
# How to generate:
#   pip install py-vapid
#   vapid --gen                   # creates private_key.pem and public_key.pem
#   vapid --applicationServerKey  # prints the two values below
#
# From the output:
#   "Application Server Key" → VAPID_PUBLIC_KEY (and VITE_VAPID_PUBLIC_KEY)
#   "Private key"            → VAPID_PRIVATE_KEY
#
# The .pem files are only needed to reprint the keys later — you do not need
# to keep them on the server.
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=

# Contact email included in VAPID claims. Used by browser vendors to reach you
# if there are delivery issues — not shown to end users.
VAPID_CLAIMS_EMAIL=admin@example.com

# ── Frontend ──────────────────────────────────────────────
# URL the browser uses to reach the API. No trailing slash.
# For a reverse-proxy setup this is typically https://yourdomain.com/api.
VITE_API_BASE_URL=https://yourdomain.com/api

# Same value as VAPID_PUBLIC_KEY — duplicated because Vite embeds it in the
# service worker at build time.
VITE_VAPID_PUBLIC_KEY=
